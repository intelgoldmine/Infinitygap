# Copy to .env locally (never commit real secrets).
# Vite variables must be prefixed with VITE_

# ── Supabase (browser-safe keys only) ──
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ── X / Twitter API (server-side only — DO NOT use VITE_ for bearer tokens) ──
# Configure on Supabase for Edge Functions, not in the frontend:
#   supabase secrets set TWITTER_BEARER_TOKEN=your_bearer_token
# Optional alias:
#   supabase secrets set X_BEARER_TOKEN=your_bearer_token
#
# Recent Search v2 uses Bearer (app-only) auth. Consumer API key + secret are for OAuth 1.0a
# user-context flows; this app’s social-intel function does not read them unless you add that later.
